---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get all docs, sorted by order
const docs = await getCollection('docs');
const sortedDocs = docs.sort((a, b) => 
  (a.data.order || 999) - (b.data.order || 999)
);
---

<BaseLayout title="Documentation | Kubernetes Claude MCP">
  <div class="container mx-auto px-4 py-8 md:py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-primary-600">Documentation</h1>
      <p class="text-lg md:text-xl text-slate-600 mb-8">
        Complete documentation for the Kubernetes Claude MCP server.
      </p>

      <div class="space-y-6">
        {sortedDocs.map(doc => (
          <div class="border border-secondary-300 rounded-lg p-6 bg-secondary-50 hover:bg-secondary-100 transition-colors">
            <a href={`/docs/${doc.slug}`} class="text-xl md:text-2xl font-semibold text-primary-600 hover:text-primary-700 hover:underline">
              {doc.data.title}
            </a>
            {doc.data.description && (
              <p class="text-slate-600 mt-2">{doc.data.description}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
