---
import { getCollection } from 'astro:content';

// Get all docs, sorted by order
const allDocs = await getCollection('docs');
const sortedDocs = allDocs.sort((a, b) => 
  (a.data.order || 999) - (b.data.order || 999)
);

// Get current path to highlight active item
const currentPath = Astro.url.pathname;
---

<aside class="sidebar-panel w-64 p-6 border-r border-secondary-300 bg-[#F8EDE3] hidden md:block sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto">
  <h2 class="text-xs font-bold uppercase tracking-widest mb-4 text-slate-500">Documentation</h2>
  <nav>
    <ul class="space-y-0.5">
      {sortedDocs.map(doc => {
        const docPath = `/docs/${doc.slug}`;
        const isActive = currentPath === docPath ||
                         currentPath === `${docPath}/` ||
                         currentPath === `/${doc.slug}`;

        return (
          <li>
            <a
              href={docPath}
              class={`sidebar-link group flex items-center py-2 px-3 rounded-md text-sm transition-all duration-200 ${
                isActive
                ? 'active bg-secondary-200 text-primary-800 font-semibold border-l-[3px] border-primary-500 pl-[10px]'
                : 'text-slate-600 hover:bg-secondary-200/60 hover:text-primary-700 border-l-[3px] border-transparent pl-[10px]'
              }`}
            >
              {doc.data.title}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</aside>
